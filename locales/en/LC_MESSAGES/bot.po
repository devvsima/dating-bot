#: app/keyboards/default/registration_form.py:91
msgid "📍 Отправить местоположение"
msgstr "📍 Send location"

#: app/keyboards/inline/archive.py:10
msgid "Посмотреть"
msgstr "View"

#: app/keyboards/inline/help.py:12
msgid "Написать разработчику"
msgstr "Contact the developer"

#: app/keyboards/inline/help.py:17
msgid "Официальный канал"
msgstr "Official channel"

