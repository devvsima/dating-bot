#: app/text.py:12
msgid ""
"\n"
"Привет! 👋\n"
"\n"
"Добро пожаловать в наш бот знакомств Michi! 💕\n"
"Чтобы начать, создай свой профиль — это просто и быстро.\n"
"\n"
"Желаем тебе приятных знакомств и интересных встреч!\n"
msgstr ""
"\n"
"Привіт! 👋\n"
"\n"
"Ласкаво просимо в наш бот знайомств Michi! 💕\n"
"Щоб почати, створи свій профіль - це просто і швидко.\n"
"\n"
"Бажаємо тобі приємних знайомств і цікавих зустрічей!\n"

#: app/text.py:23
msgid ""
"\n"
"👋\n"
"Немного информации о боте:\n"
"Этот бот был создан по аналогии с популярным ботом для знакомств <a href='https://"
"t.me/leomatchbot?start=i_VwRd0'>Дайвинчик</a>\n"
"Весь код бота открыт и доступен на <a href='https://github.com/devvsima/dating-"
"bot'>GitHub</a>\n"
"\n"
"По вопросам и предложениям можно писать сюда: @devvsima.\n"
msgstr ""
"\n"
"👋\n"
"Трохи інформації про бота:\n"
"Цей бот був створений за аналогією з популярним ботом для знайомств <a "
"href='https://t.me/leomatchbot?start=i_VwRd0'>Дайвінчик</a>\n"
"Весь код бота відкритий і доступний на <a href='https://github.com/devvsima/"
"dating-bot'>GitHub</a>\n"
"\n"
"З питань і пропозицій можна писати сюди: @devvsima.\n"

#: app/text.py:34
msgid ""
"\n"
"🔍 Смотреть анкеты\n"
"👤 Моя анкета\n"
"📭 Кто меня лайкнул\n"
"\n"
"✉️ Пригласить друзей"
msgstr ""
"\n"
"🔍 Дивитися анкети\n"
"👤 Моя анкета\n"
"📭 Хто мене лайкнув\n"
"\n"
"✉️ Запросити друзів"

#: app/text.py:43
msgid ""
"\n"
"🔄 Заполнить анкету заново\n"
"🖼 Изменить фотографию\n"
"✍️ Изменить описание\n"
"❌ Отключить анкету\n"
"\n"
"↩️ Назад\n"
msgstr ""
"\n"
"🔄 Заповнити анкету заново\n"
"🖼 Змінити фотографію\n"
"✍️ Змінити опис\n"
"❌ Відключити анкету\n"
"\n"
"↩️ Назад\n"

#: app/text.py:55
msgid "Неизвестная команда. Если заблудился, напиши /start."
msgstr "Невідома команда. Якщо заблукав, напиши /start."

#: app/text.py:62
msgid "Укажи, свой пол: 👤"
msgstr "Вкажи, свою стать: 👤"

#: app/text.py:66
msgid "Выбери, кого ты ищешь: 💕"
msgstr "Вибери, кого ти шукаєш: 💕"

#: app/text.py:70
msgid "Загрузи своё фото! Можно отправить до 3 фотографий одновременно 📸"
msgstr "Завантаж своє фото! Можна відправити до 3 фотографій одночасно 📸"

#: app/text.py:74
msgid "Как тебя зовут? ✍️"
msgstr "Як тебе звати? ✍️"

#: app/text.py:78
msgid "Сколько тебе лет? 🎂"
msgstr "Скільки тобі років? 🎂"

#: app/text.py:82
msgid "Укажи свой город: 🏙️"
msgstr "Вкажи своє місто: 🏙️"

#: app/text.py:86
msgid "Расскажи немного о себе — это поможет другим узнать тебя лучше! 📝"
msgstr "Розкажи трохи про себе — це допоможе іншим краще тебе пізнати! 📝"

#: app/text.py:90
msgid ""
"Отлично! Твой профиль готов — теперь можешь искать интересных для себя людей 💬"
msgstr "Чудово! Твій профіль готовий - тепер можеш шукати цікавих для себе людей 💬"

#: app/text.py:94
msgid ""
"\n"
"❌ Твоя анкета отключена, некоторые функции теперь недоступны.\n"
"💬 Чтобы снова активировать анкету, отправь команду /start."
msgstr ""
"\n"
"❌ Твоя анкета відключена, деякі функції тепер недоступні.\n"
"💬 Щоб знову активувати анкету, надішли команду /start."

#: app/text.py:100
msgid ""
"✅ Твоя анкета успешно восстановлена! Теперь ты снова можешь пользоваться ботом."
msgstr ""
"✅ Твою анкету успішно відновлено! Тепер ти знову можеш користуватися ботом."

#: app/text.py:104
msgid "🔍 Выполняется поиск..."
msgstr "🔍 Виконується пошук..."

#: app/text.py:108
#, python-brace-format
msgid "Твоя анкета понравилась {} людям! Давай посмотрим, кто это:"
msgstr "Твоя анкета сподобалася {} людям! Давай подивимося, хто це:"

#: app/text.py:112
msgid "Подходящих анкет не найдено. Попробуй выбрать другой город. 🌍"
msgstr "Відповідних анкет не знайдено. Спробуй вибрати інше місто. 🌍"

#: app/text.py:116
msgid "Анкеты закончились. Попробуй позже! 😊"
msgstr "Анкети закінчилися. Спробуй пізніше! 😊"

#: app/text.py:120
#, python-brace-format
msgid ""
"Твоя анкета получила <b>{}</b> ❤️\n"
"\n"
"📭 Нажми, чтобы посмотреть"
msgstr ""
"Твоя анкета отримала <b>{}</b> ❤️\n"
"\n"
"📭 Натисни, щоб подивитися"

#: app/text.py:126
msgid "Пока никто не поставил тебе лайк, но всё ещё впереди!"
msgstr "Поки що ніхто не поставив тобі лайк, але все ще попереду!"

#: app/text.py:130
#, python-brace-format
msgid "Надеюсь вы хорошо проведете время ;) <a href='{}'>{}</a>"
msgstr "Сподіваюся, ви добре проведете час ;) <a href='{}'>{}</a>"

#: app/text.py:142
#, python-brace-format
msgid ""
"Сообщение для тебя:\n"
"{}"
msgstr ""
"Повідомлення для тебе:\n"
"{}"

#: app/text.py:147
msgid ""
"Можешь написать пользователю, до 250 символов. ✉️\n"
"\n"
"Если не хочешь писать, нажми на кнопку ниже."
msgstr ""
"Можеш написати користувачеві, до 250 символів. ✉️\n"
"\n"
"Якщо не хочеш писати, натисни на кнопку нижче."

#: app/text.py:152
msgid "Отправил сообщение, ждем ответа."
msgstr "Відправив повідомлення, чекаємо відповіді."

#: app/text.py:156
msgid "Не корректное сообщение. Пожалуйста, напиши до 250 символов."
msgstr "Некоректне повідомлення. Будь ласка, напиши до 250 символів."

#: app/text.py:160
msgid "Хорошо, ничего не буду отправлять."
msgstr "Добре, нічого не буду надсилати."

#: app/text.py:165
msgid ""
"Некорректный ответ. Пожалуйста, выбери на клавиатуре или напиши правильно. 📝"
msgstr ""
"Некоректна відповідь. Будь ласка, вибери на клавіатурі або напиши правильно. 📝"

#: app/text.py:169
msgid "Превышен лимит символов. Пожалуйста, сократи сообщение. ✂️"
msgstr "Перевищено ліміт символів. Будь ласка, скоротіть повідомлення. ✂️"

#: app/text.py:173
msgid ""
"Некорректное имя. Имя должно содержать минимум 2 буквы и максимум 70 символов. ✍️"
msgstr ""
"Некоректне ім'я. Ім'я повинно містити мінімум 2 літери і максимум 70 символів. ✍️"

#: app/text.py:177
msgid "Такой город не найден 😔"
msgstr "Таке місто не знайдено 😔"

#: app/text.py:182
msgid ""
"Неверный формат фотографии! Пожалуйста, загрузите изображение в правильном "
"формате. 🖼️"
msgstr ""
"Неправильний формат фотографії! Будь ласка, завантажте зображення в правильному "
"форматі. 🖼️"

#: app/text.py:187
msgid "Неверный формат, возраст нужно указывать цифрами. 🔢"
msgstr "Неправильний формат, вік потрібно вказувати цифрами. 🔢"

#: app/text.py:192
#, python-brace-format
msgid ""
"Приглашай друзей и получай бонусы!\n"
"\n"
"Приглашенные пользователи: <b>{}</b>\n"
"\n"
"Ссылка для друзей:\n"
"<code>{}</code>"
msgstr ""
"Запрошуй друзів та отримуй бонуси!\n"
"\n"
"Запрошені користувачі: <b>{}</b>\n"
"\n"
"Посилання для друзів:\n"
"<code>{}</code>"

#: app/text.py:197
#, python-brace-format
msgid ""
"Наш канал:\n"
"{}"
msgstr ""
"Наш канал:\n"
"{}"

#: app/text.py:202
msgid "Выбери язык бота, на который хочешь переключиться: 🌐"
msgstr "Обери мову бота, на яку хочеш переключитися: 🌐"

#: app/text.py:205
msgid "Язык бота изменён! ✅"
msgstr "Мова бота змінена! ✅"

#: app/text.py:210
msgid ""
"\n"
"Укажи причину жалобы:\n"
"🔞 Неприличный контент\n"
"💰 Реклама\n"
"🔫 Другое\n"
"\n"
"↩️ Назад\n"
msgstr ""
"\n"
"Вкажи причину скарги:\n"
"🔞 Непристойний контент\n"
"💰 Реклама\n"
"🔫 Інше\n"
"\n"
"↩️ Назад\n"

#: app/text.py:230
msgid "✅ Жалоба успешно отправлена на рассмотрение!"
msgstr "✅ Скарга успішно відправлена на розгляд!"

#: app/text.py:235
msgid "Загрузи новые фото! Можно отправить до 3 фотографий 📸"
msgstr "Завантаж нові фото! Можна надіслати до 3 фото 📸"

#: app/text.py:239
msgid "Фотографии остались без изменений"
msgstr "Фотографії залишилися без змін"

#: app/text.py:243
msgid "Вы не загрузили ни одного фото. Попробуйте еще раз."
msgstr "Ви не завантажили жодного фото. Спробуйте ще раз."

#: app/text.py:247
msgid "❌ Ошибка при сохранении фото. Попробуйте еще раз."
msgstr "❌ Помилка під час збереження фото. Спробуйте ще раз."

#: app/keyboards/default/registration_form.py:55 app/text.py:251 app/text.py:261
msgid "Это все, сохранить фото"
msgstr "Це все, зберегти фото"

#: app/text.py:256
#, python-brace-format
msgid ""
"📸 Фото {current}/{total} загружено!\n"
"\n"
"Можете загрузить еще {remaining} фото или нажать '{finish_button}'"
msgstr ""
"📸 Фото {current}/{total} завантажено!\n"
"\n"
"Можете завантажити ще {remaining} фото або натиснути '{finish_button}'"

#: app/text.py:267
#, python-brace-format
msgid "Сохранено {} фото!"
msgstr "Збережено {} фото!"

#: app/text.py:270
#, python-brace-format
msgid "Все {} фото загружены!"
msgstr "Всі {} фото завантажено!"

#: app/text.py:274
msgid "❌ Максимум 3 фото! Нажмите 'Это все, сохранить фото' для сохранения."
msgstr "❌ Максимум 3 фото! Натисніть 'Це все, зберегти фото' для збереження."

#: app/text.py:278
msgid "📸 Отправьте фотографию или выберите действие из меню"
msgstr "📸 Надішліть фотографію або оберіть дію з меню"

#: app/text.py:282
msgid "❌ Для создания профиля необходимо загрузить хотя бы одно фото!"
msgstr "❌ Для створення профілю необхідно завантажити щонайменше одне фото!"

#: app/text.py:286
msgid ""
"⏳ Вы отправляете сообщения слишком часто. Пожалуйста, подождите пару секунд."
msgstr ""
"⏳ Ви надсилаєте повідомлення занадто часто. Будь ласка, зачекайте кілька секунд."

#: app/text.py:292
msgid "Поддержка проекта"
msgstr "Підтримка проекту"

#: app/keyboards/default/registration_form.py:16
msgid "Создать анкету"
msgstr "Створити анкету"

#: app/keyboards/default/registration_form.py:29
msgid "Парень"
msgstr "Хлопець"

#: app/keyboards/default/registration_form.py:29
msgid "Девушка"
msgstr "Дівчина"

#: app/keyboards/default/registration_form.py:40
msgid "Парней"
msgstr "Хлопців"

#: app/keyboards/default/registration_form.py:41
msgid "Девушек"
msgstr "Дівчат"

#: app/keyboards/default/registration_form.py:42
msgid "Всех"
msgstr "Усіх"

#: app/keyboards/default/registration_form.py:79
#: app/keyboards/default/registration_form.py:89
#: app/keyboards/default/registration_form.py:104
msgid "Оставить предыдущее"
msgstr "Залишити попереднє"

#: app/keyboards/default/registration_form.py:80
msgid "Пропустить"
msgstr "Пропустити"

#: app/keyboards/default/registration_form.py:91
msgid "📍 Отправить местоположение"
msgstr "📍 Надіслати місцеположення"

#: app/keyboards/inline/archive.py:10
msgid "Посмотреть"
msgstr "Подивитися"

#: app/keyboards/inline/help.py:12
msgid "Написать разработчику"
msgstr "Написати розробнику"

#: app/keyboards/inline/help.py:17
msgid "Официальный канал"
msgstr "Офіційний канал"

#: app/keyboards/inline/help.py:23
msgid "Поддержать проект"
msgstr "Підтримати проек"

