#: app/text.py:12
msgid ""
"\n"
"Привет! 👋\n"
"\n"
"Добро пожаловать в наш бот знакомств Michi! 💕\n"
"Чтобы начать, создай свой профиль — это просто и быстро.\n"
"\n"
"Желаем тебе приятных знакомств и интересных встреч!\n"
msgstr ""
"\n"
"Halo! 👋\n"
"\n"
"Selamat datang di bot kencan Michi! 💕\n"
"Untuk memulai, buat profilmu — mudah dan cepat.\n"
"\n"
"Semoga kamu mendapatkan pertemanan dan pertemuan yang menyenangkan!\n"

#: app/text.py:23
msgid ""
"\n"
"👋\n"
"Немного информации о боте:\n"
"Этот бот был создан по аналогии с популярным ботом для знакомств <a "
"href='https://t.me/leomatchbot?start=i_VwRd0'>Дайвинчик</a>\n"
"Весь код бота открыт и доступен на <a href='https://github.com/devvsima/dating-"
"bot'>GitHub</a>\n"
"\n"
"По вопросам и предложениям можно писать сюда: @devvsima.\n"
msgstr ""
"\n"
"👋\n"
"Sedikit informasi tentang bot:\n"
"Bot ini dibuat berdasarkan bot kencan populer <a href='https://t.me/leomatchbot?"
"start=i_VwRd0'>Leomatchbot</a>\n"
"Seluruh kode bot terbuka dan tersedia di <a href='https://github.com/devvsima/"
"dating-bot'>GitHub</a>\n"
"\n"
"Untuk pertanyaan dan saran, silakan hubungi: @devvsima.\n"

#: app/text.py:34
msgid ""
"\n"
"🔍 Смотреть анкеты\n"
"👤 Моя анкета\n"
"📭 Кто меня лайкнул\n"
"\n"
"✉️ Пригласить друзей"
msgstr ""
"\n"
"🔍 Lihat profil\n"
"👤 Profil saya\n"
"📭 Siapa yang menyukai saya\n"
"\n"
"✉️ Undang teman"

#: app/text.py:43
msgid ""
"\n"
"🔄 Заполнить анкету заново\n"
"🖼 Изменить фотографию\n"
"✍️ Изменить описание\n"
"❌ Отключить анкету\n"
"\n"
"↩️ Назад\n"
msgstr ""
"\n"
"🔄 Isi ulang profil\n"
"🖼 Ubah foto\n"
"✍️ Ubah deskripsi\n"
"❌ Nonaktifkan profil\n"
"\n"
"↩️ Kembali\n"

#: app/text.py:55
msgid "Неизвестная команда. Если заблудился, напиши /start."
msgstr "Perintah tidak dikenal. Jika bingung, ketik /start."

#: app/text.py:62
msgid "Укажи, свой пол: 👤"
msgstr "Pilih jenis kelaminmu: 👤"

#: app/text.py:66
msgid "Выбери, кого ты ищешь: 💕"
msgstr "Pilih siapa yang kamu cari: 💕"

#: app/text.py:70
msgid "Загрузи своё фото! Можно отправить до 3 фотографий одновременно 📸"
msgstr "Unggah fotomu! Kamu bisa mengirim hingga 3 foto sekaligus 📸"

#: app/text.py:74
msgid "Как тебя зовут? ✍️"
msgstr "Siapa namamu? ✍️"

#: app/text.py:78
msgid "Сколько тебе лет? 🎂"
msgstr "Berapa umurmu? 🎂"

#: app/text.py:82
msgid "Укажи свой город: 🏙️"
msgstr "Tulis kotamu: 🏙️"

#: app/text.py:86
msgid "Расскажи немного о себе — это поможет другим узнать тебя лучше! 📝"
msgstr "Ceritakan sedikit tentang dirimu — ini membantu orang lain mengenalmu! 📝"

#: app/text.py:90
msgid ""
"Отлично! Твой профиль готов — теперь можешь искать интересных для себя людей 💬"
msgstr "Profilmu sudah siap — sekarang kamu bisa mencari orang menarik 💬"

#: app/text.py:94
msgid ""
"\n"
"❌ Твоя анкета отключена, некоторые функции теперь недоступны.\n"
"💬 Чтобы снова активировать анкету, отправь команду /start."
msgstr ""
"\n"
"❌ Profilmu dinonaktifkan, beberapa fitur tidak tersedia.\n"
"💬 Untuk mengaktifkan kembali profil, kirim perintah /start."

#: app/text.py:100
msgid ""
"✅ Твоя анкета успешно восстановлена! Теперь ты снова можешь пользоваться ботом."
msgstr "✅ Profilmu berhasil dipulihkan! Kamu bisa menggunakan bot lagi."

#: app/text.py:104
msgid "🔍 Выполняется поиск..."
msgstr "🔍 Sedang mencari..."

#: app/text.py:108
#, python-brace-format
msgid "Твоя анкета понравилась {} людям! Давай посмотрим, кто это:"
msgstr "Profilmu disukai oleh {} orang! Mari lihat siapa saja:"

#: app/text.py:112
msgid "Подходящих анкет не найдено. Попробуй выбрать другой город. 🌍"
msgstr "Tidak ada profil yang cocok ditemukan. Coba pilih kota lain. 🌍"

#: app/text.py:116
msgid "Анкеты закончились. Попробуй позже! 😊"
msgstr "Profil sudah habis. Coba lagi nanti! 😊"

#: app/text.py:120
#, python-brace-format
msgid ""
"Твоя анкета получила <b>{}</b> ❤️\n"
"\n"
"📭 Нажми, чтобы посмотреть"
msgstr ""
"Profilmu mendapat <b>{}</b> ❤️\n"
"\n"
"📭 Klik untuk melihat"

#: app/text.py:126
msgid "Пока никто не поставил тебе лайк, но всё ещё впереди!"
msgstr "Belum ada yang menyukaimu, tapi semuanya masih mungkin!"

#: app/text.py:130
#, python-brace-format
msgid "Надеюсь вы хорошо проведете время ;) <a href='{}'>{}</a>"
msgstr "Semoga kalian bersenang-senang ;) <a href='{}'>{}</a>"

#: app/text.py:142
#, python-brace-format
msgid ""
"Сообщение для тебя:\n"
"{}"
msgstr ""
"Pesan untukmu:\n"
"{}"

#: app/text.py:147
msgid ""
"Можешь написать пользователю, до 250 символов. ✉️\n"
"\n"
"Если не хочешь писать, нажми на кнопку ниже."
msgstr ""
"Kamu bisa menulis pesan hingga 250 karakter. ✉️\n"
"\n"
"Jika tidak ingin menulis, klik tombol di bawah."

#: app/text.py:152
msgid "Отправил сообщение, ждем ответа."
msgstr "Pesan dikirim, tunggu balasan."

#: app/text.py:156
msgid "Не корректное сообщение. Пожалуйста, напиши до 250 символов."
msgstr "Pesan tidak valid. Silakan tulis hingga 250 karakter."

#: app/text.py:160
msgid "Хорошо, ничего не буду отправлять."
msgstr "Baik, tidak akan mengirim apa pun."

#: app/text.py:165
msgid ""
"Некорректный ответ. Пожалуйста, выбери на клавиатуре или напиши правильно. 📝"
msgstr "Jawaban tidak valid. Silakan pilih di keyboard atau tulis dengan benar. 📝"

#: app/text.py:169
msgid "Превышен лимит символов. Пожалуйста, сократи сообщение. ✂️"
msgstr "Melebihi batas karakter. Silakan perpendek pesanmu. ✂️"

#: app/text.py:173
msgid ""
"Некорректное имя. Имя должно содержать минимум 2 буквы и максимум 70 символов. ✍️"
msgstr ""
"Nama tidak valid. Nama harus terdiri dari minimal 2 huruf dan maksimal 70 "
"karakter. ✍️"

#: app/text.py:177
msgid "Такой город не найден 😔"
msgstr "Kota seperti itu tidak ditemukan 😔"

#: app/text.py:182
msgid ""
"Неверный формат фотографии! Пожалуйста, загрузите изображение в правильном "
"формате. 🖼️"
msgstr "Format foto salah! Silakan unggah gambar dengan format yang benar. 🖼️"

#: app/text.py:187
msgid "Неверный формат, возраст нужно указывать цифрами. 🔢"
msgstr "Format salah, umur harus ditulis dengan angka. 🔢"

#: app/text.py:192
#, python-brace-format
msgid ""
"Приглашай друзей и получай бонусы!\n"
"\n"
"Приглашенные пользователи: <b>{}</b>\n"
"\n"
"Ссылка для друзей:\n"
"<code>{}</code>"
msgstr ""
"Undang teman dan dapatkan bonus!\n"
"\n"
"Pengguna yang diundang: <b>{}</b>\n"
"\n"
"Tautan untuk teman:\n"
"<code>{}</code>"

#: app/text.py:197
#, python-brace-format
msgid ""
"Наш канал:\n"
"{}"
msgstr ""
"Channel kami:\n"
"{}"

#: app/text.py:202
msgid "Выбери язык бота, на который хочешь переключиться: 🌐"
msgstr "Pilih bahasa bot yang ingin kamu gunakan: 🌐"

#: app/text.py:205
msgid "Язык бота изменён! ✅"
msgstr "Bahasa bot telah diubah! ✅"

#: app/text.py:210
msgid ""
"\n"
"Укажи причину жалобы:\n"
"🔞 Неприличный контент\n"
"💰 Реклама\n"
"🔫 Другое\n"
"\n"
"↩️ Назад\n"
msgstr ""
"\n"
"Tulis alasan laporan:\n"
"🔞 Konten tidak pantas\n"
"💰 Iklan\n"
"🔫 Lainnya\n"
"\n"
"↩️ Kembali\n"

#: app/text.py:230
msgid "✅ Жалоба успешно отправлена на рассмотрение!"
msgstr "✅ Laporan berhasil dikirim untuk ditinjau!"

#: app/text.py:235
msgid "Загрузи новые фото! Можно отправить до 3 фотографий 📸"
msgstr "Unggah foto baru! Kamu bisa mengirim hingga 3 foto 📸"

#: app/text.py:239
msgid "Фотографии остались без изменений"
msgstr "Foto tidak berubah"

#: app/text.py:243
msgid "Вы не загрузили ни одного фото. Попробуйте еще раз."
msgstr "Kamu belum mengunggah foto. Silakan coba lagi."

#: app/text.py:247
msgid "❌ Ошибка при сохранении фото. Попробуйте еще раз."
msgstr "❌ Gagal menyimpan foto. Silakan coba lagi."

#: app/keyboards/default/registration_form.py:55 app/text.py:251 app/text.py:261
msgid "Это все, сохранить фото"
msgstr "Selesai, simpan foto"

#: app/text.py:256
#, python-brace-format
msgid ""
"📸 Фото {current}/{total} загружено!\n"
"\n"
"Можете загрузить еще {remaining} фото или нажать '{finish_button}'"
msgstr ""
"📸 Foto {current}/{total} diunggah!\n"
"\n"
"Kamu bisa mengunggah {remaining} foto lagi atau klik '{finish_button}'"

#: app/text.py:267
#, python-brace-format
msgid "Сохранено {} фото!"
msgstr "{} foto disimpan!"

#: app/text.py:270
#, python-brace-format
msgid "Все {} фото загружены!"
msgstr "Semua {} foto diunggah!"

#: app/text.py:274
msgid "❌ Максимум 3 фото! Нажмите 'Это все, сохранить фото' для сохранения."
msgstr "❌ Maksimal 3 foto! Klik 'Selesai, simpan foto' untuk menyimpan."

#: app/text.py:278
msgid "📸 Отправьте фотографию или выберите действие из меню"
msgstr "📸 Kirim foto atau pilih aksi dari menu"

#: app/text.py:282
msgid "❌ Для создания профиля необходимо загрузить хотя бы одно фото!"
msgstr "❌ Untuk membuat profil, kamu harus mengunggah minimal satu foto!"

#: app/text.py:286
msgid ""
"⏳ Вы отправляете сообщения слишком часто. Пожалуйста, подождите пару секунд."
msgstr "⏳ Anda mengirim pesan terlalu sering. Mohon tunggu beberapa detik."

#: app/text.py:292
msgid "Поддержка проекта"
msgstr "Dukungan untuk proyek ini"

#: app/keyboards/default/registration_form.py:16
msgid "Создать анкету"
msgstr "Buat profil"

#: app/keyboards/default/registration_form.py:29
msgid "Парень"
msgstr "Laki-laki"

#: app/keyboards/default/registration_form.py:29
msgid "Девушка"
msgstr "Perempuan"

#: app/keyboards/default/registration_form.py:40
msgid "Парней"
msgstr "Laki-laki"

#: app/keyboards/default/registration_form.py:41
msgid "Девушек"
msgstr "Perempuan"

#: app/keyboards/default/registration_form.py:42
msgid "Всех"
msgstr "Semua"

#: app/keyboards/default/registration_form.py:79
#: app/keyboards/default/registration_form.py:89
#: app/keyboards/default/registration_form.py:104
msgid "Оставить предыдущее"
msgstr "Biarkan yang sebelumnya"

#: app/keyboards/default/registration_form.py:80
msgid "Пропустить"
msgstr "Lewati"

#: app/keyboards/default/registration_form.py:91
msgid "📍 Отправить местоположение"
msgstr "📍 Kirim lokasi"

#: app/keyboards/inline/archive.py:10
msgid "Посмотреть"
msgstr "Lihat"

#: app/keyboards/inline/help.py:12
msgid "Написать разработчику"
msgstr "Menghubungi pengembang"

#: app/keyboards/inline/help.py:17
msgid "Официальный канал"
msgstr "Saluran resmi"

#: app/keyboards/inline/help.py:23
msgid "Поддержать проект"
msgstr "Dukung proyek ini"

